# ── Frontend (Vite) — add to Netlify environment variables ──────────────────
# All VITE_ vars are public (bundled into the client)

# Supabase — get from https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe publishable key — get from https://dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create at https://dashboard.stripe.com → Products
# Create two products: "Analyst" ($7/mo) and "Scout" ($15/mo)
VITE_STRIPE_PRICE_PRO=price_...
VITE_STRIPE_PRICE_ELITE=price_...


# ── Backend (Render) — add to Render environment variables ───────────────────
# These are server-side secrets, never exposed to the browser

# Stripe secret key
STRIPE_SECRET_KEY=sk_live_...

# Stripe webhook signing secret — from https://dashboard.stripe.com → Webhooks
# Point webhook to: https://YOUR_RENDER_URL/webhook
# Events to listen: checkout.session.completed, customer.subscription.updated,
#                   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (same as frontend, needed for tier mapping)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ELITE=price_...

# Supabase service role key (admin, server-side only)
# Get from: https://app.supabase.com → Settings → API → service_role key
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Frontend URL (for Stripe redirect URLs)
FRONTEND_URL=https://predictafc.netlify.app
